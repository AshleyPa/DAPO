# DAPO V2 Sealos environment example.
# Copy values into Sealos Secret / environment variables. Do not commit real
# passwords, private keys, app secrets, or production DSNs.

KLEIN_ENV=prod

# Images built from the local source repo and pushed to your registry.
DAPO_BACKEND_IMAGE=registry.example.com/dapo/backend:CHANGE_ME
DAPO_USER_WEB_IMAGE=registry.example.com/dapo/user-web:CHANGE_ME
DAPO_ADMIN_WEB_IMAGE=registry.example.com/dapo/admin-web:CHANGE_ME

# Sealos managed MySQL / SQL service.
KLEIN_DB_DSN=dapo_user:CHANGE_ME@tcp(dapo-mysql.ns-example.svc:3306)/dapo_v2?charset=utf8mb4&parseTime=True&loc=Local

# Sealos Redis App Launchpad service.
KLEIN_REDIS_ADDR=dapo-redis.ns-example.svc:6379
KLEIN_REDIS_PASSWORD=
KLEIN_REDIS_DB=0

# JWT and credential encryption. Generate fresh production values.
KLEIN_JWT_SECRET=CHANGE_ME_64_HEX_OR_LONG_RANDOM
KLEIN_JWT_REFRESH_SECRET=CHANGE_ME_64_HEX_OR_LONG_RANDOM
KLEIN_AES_KEY=CHANGE_ME_32_BYTE_AES_KEY

# Public origins.
KLEIN_CORS_ORIGINS=https://www.dapo-ai.com,https://admin.dapo-ai.com
DAPO_USER_WEB_PORT=17080
DAPO_ADMIN_WEB_PORT=17088
KLEIN_API_PORT=17180
KLEIN_ADMIN_PORT=17188
KLEIN_OPENAI_PORT=17200

# Provider mode.
KLEIN_PROVIDER_GPT=real
KLEIN_PROVIDER_GROK=real
KLEIN_GPT_BASE_URL=https://api.openai.com
KLEIN_GROK_BASE_URL=https://api.x.ai

# Aliyun enterprise email verification.
KLEIN_SMTP_HOST=smtp.qiye.aliyun.com
KLEIN_SMTP_PORT=465
KLEIN_SMTP_USERNAME=ashley@dapo-ai.com
KLEIN_SMTP_PASSWORD=CHANGE_ME_SECRET
KLEIN_SMTP_FROM_EMAIL=ashley@dapo-ai.com
KLEIN_SMTP_FROM_NAME=DAPO达波显影
KLEIN_SMTP_USE_SSL=true
KLEIN_SMTP_USE_STARTTLS=false

# Alipay face-to-face payment.
KLEIN_PAYMENT_ENABLED=true
KLEIN_PAYMENT_PROVIDER=alipay
KLEIN_PAYMENT_NOTIFY_URL=https://www.dapo-ai.com/api/v1/billing/recharge/alipay/notify
KLEIN_ALIPAY_APP_ID=CHANGE_ME
KLEIN_ALIPAY_SELLER_ID=CHANGE_ME
KLEIN_ALIPAY_PRIVATE_KEY=CHANGE_ME_SECRET
KLEIN_ALIPAY_PUBLIC_KEY=CHANGE_ME_PUBLIC_KEY
KLEIN_ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
KLEIN_ALIPAY_SUBJECT_PREFIX=DAPO达波显影-
KLEIN_ALIPAY_RECONCILE_INTERVAL=2m
KLEIN_ALIPAY_RECONCILE_LIMIT=100
